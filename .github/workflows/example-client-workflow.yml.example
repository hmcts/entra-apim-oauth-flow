# Example workflow for client projects
# Copy this file to your client project as .github/workflows/test-entra-apim.yml
# 
# IMPORTANT: 
# 1. Replace 'your-org/entra-apim-oauth-flow' with the actual repository path
# 2. Set the required secrets in your repository: Settings → Secrets and variables → Actions
#    - TENANT_ID, CLIENT_ID, CLIENT_SECRET, API_APP_ID_URI, APIM_BASE_URL, SUBSCRIPTION_KEY, SLUG
# 3. Set SLUG secret: API slug/path for the endpoint (e.g., /amp-oauth/case/C9LJXVS5NQ/courtschedule)

name: Test Entra APIM OAuth

on:
  workflow_dispatch:
  push:
    branches: [main, master]
  pull_request:
    branches: [main, master]

jobs:
  test:
    uses: your-org/entra-apim-oauth-flow/.github/workflows/test.yml@main
    # Pass required inputs (can reference secrets from your repository)
    with:
      tenant_id: ${{ secrets.TENANT_ID }}
      client_id: ${{ secrets.CLIENT_ID }}
      client_secret: ${{ secrets.CLIENT_SECRET }}
      api_app_id_uri: ${{ secrets.API_APP_ID_URI }}
      apim_base_url: ${{ secrets.APIM_BASE_URL }}
      subscription_key: ${{ secrets.SUBSCRIPTION_KEY }}
      slug: ${{ secrets.SLUG }}
    # Optionally pass as secrets (they will take precedence over inputs if provided)
    secrets:
      tenant_id: ${{ secrets.TENANT_ID }}
      client_id: ${{ secrets.CLIENT_ID }}
      client_secret: ${{ secrets.CLIENT_SECRET }}
      api_app_id_uri: ${{ secrets.API_APP_ID_URI }}
      apim_base_url: ${{ secrets.APIM_BASE_URL }}
      subscription_key: ${{ secrets.SUBSCRIPTION_KEY }}
      slug: ${{ secrets.SLUG }}

